# ==============================================================================
# Jenkins Training Environment - Konfiguration
# ==============================================================================
# Kopiere diese Datei nach config.env und passe die Werte an:
#   cp config.env.example config.env
# ==============================================================================

# --- Pflichtparameter ---------------------------------------------------------

# IP-Adresse oder Hostname der Ziel-VM
TARGET_HOST="192.168.1.100"

# Pfad zum privaten SSH-Key
SSH_KEY_PATH="~/.ssh/id_rsa"

# SSH-Benutzer auf der VM
SSH_USER="ubuntu"

# --- Optionale Parameter ------------------------------------------------------

# Domain-Name fuer die Jenkins-Instanz (fuer Nginx + Let's Encrypt SSL)
# Wenn gesetzt, wird Nginx als Reverse Proxy mit Let's Encrypt Zertifikat konfiguriert
# Die Domain muss per DNS auf TARGET_HOST zeigen, Port 80 muss von aussen erreichbar sein
#DOMAIN_NAME="jenkins.example.com"

# E-Mail-Adresse fuer Let's Encrypt Zertifikats-Benachrichtigungen
#LETSENCRYPT_EMAIL="admin@example.com"

# SSH-Port (Standard: 22)
#SSH_PORT="22"

# Jenkins Web-UI Port (Standard: 8080)
#JENKINS_PORT="8080"

# Jenkins-Version: "lts", "latest" oder spezifische Version z.B. "2.462.1"
#JENKINS_VERSION="lts"

# Java-Version: "17" oder "21"
#JAVA_VERSION="17"

# Docker auf dem Jenkins-Host installieren (true/false)
#INSTALL_DOCKER="true"

# Zusaetzliche Jenkins-Plugins (kommasepariert)
# Standard-Plugins werden immer installiert, hier koennen weitere ergaenzt werden
#INSTALL_PLUGINS="ansible,terraform,kubernetes"

# Jenkins Admin-Benutzername
#ADMIN_USER="admin"

# Jenkins Admin-Passwort (wird generiert wenn leer)
#ADMIN_PASSWORD=""

# Anzahl zusaetzlicher Jenkins-Agenten (0-5)
#AGENT_COUNT="0"

# Nginx als Reverse Proxy installieren (true/false)
# Wird automatisch aktiviert wenn DOMAIN_NAME gesetzt ist
#NGINX_REVERSE_PROXY="false"
